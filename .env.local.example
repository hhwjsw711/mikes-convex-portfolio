# Convex
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# YouTube Data API v3
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key

# Your YouTube channel ID (not the handle like @convex-dev, but the actual channel ID)
# Find it by going to your channel and looking at the URL, or use https://www.youtube.com/account_advanced
# For @convex-dev, the channel ID can be found by visiting the channel page
YOUTUBE_CHANNEL_ID=your-channel-id

# Convex Stack author slug (the part after /author/ in the URL)
STACK_AUTHOR_SLUG=mike-cann

# X (Twitter) API credentials
# Get your Bearer Token from: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=your-x-bearer-token
# Your X user ID (numeric ID, not username)
# Find it by calling: https://api.twitter.com/2/users/by/username/YOUR_USERNAME
X_USER_ID=your-x-user-id

# Admin authentication
# Set a secure password for admin login
ADMIN_PASSWORD=your-secure-password

# Disable cron jobs (useful for dev environments to avoid rate limits)
# Set to "true" to disable all scheduled cron jobs
DISABLE_CRONS=true
